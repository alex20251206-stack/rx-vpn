#!/bin/bash
# OpenVPN + stunnel client for ovpn-panel:
# stunnel TLS -> server:443, OpenVPN -> 127.0.0.1:<local port>.

set -euo pipefail

readonly CONF_BASENAME="${OVPN_CONF_BASENAME:-rx}"
readonly STATE_DIR="/etc/rx-vpn"
readonly URL_FILE="${STATE_DIR}/subscription.url"
readonly LOCAL_PORT_FILE="${STATE_DIR}/local.port"
readonly CA_FILE="${STATE_DIR}/stunnel-ca.pem"
readonly CLIENT_CONF="/etc/openvpn/client/${CONF_BASENAME}.conf"
readonly STUNNEL_UNIT="stunnel@${CONF_BASENAME}.service"
readonly STUNNEL_CONF="/etc/stunnel/${CONF_BASENAME}.conf"
readonly OVPN_UNIT="openvpn-client@${CONF_BASENAME}.service"
readonly OVPN_DROPIN_DIR="/etc/systemd/system/openvpn-client@${CONF_BASENAME}.service.d"
readonly OVPN_DROPIN="${OVPN_DROPIN_DIR}/stunnel.conf"
# Stunnel + OpenVPN append to the same file (set OVPN_UNIFIED_LOG to override).
readonly UNIFIED_LOG="${OVPN_UNIFIED_LOG:-/var/log/rx-vpn/client.log}"

usage() {
  cat <<'EOF'
Usage: ovpn-panel-client <command>

  set-url <url>   Save subscription URL, download .ovpn, configure stunnel
                  (TLS to server) + OpenVPN (to 127.0.0.1:<local port>),
                  enable and start both systemd units.
  refresh         Re-download and restart stunnel + OpenVPN.
  status          Show saved URL, ports, and unit states.
  logs            Follow unified log (stunnel + OpenVPN) — tail -f.
  disable         Stop and disable OpenVPN and stunnel units (configs kept).

Environment:
  OVPN_CONF_BASENAME   Profile name without .conf (default: rx).
  OVPN_LOCAL_PORT      Local TCP port for OpenVPN (default: 11941). Saved
                       in /etc/rx-vpn/local.port after set-url.
  OVPN_UNIFIED_LOG     Path for combined log (default: /var/log/rx-vpn/client.log).

Data flow: OpenVPN -> 127.0.0.1:<local> -> stunnel -> TLS -> server:443 -> stunnel -> OpenVPN server.

Subscription URL: .../api/subscription/<client_id>?token=<panel_token>
EOF
}

require_root() {
  if [[ "${EUID:-}" -ne 0 ]]; then
    echo "error: run as root (sudo)" >&2
    exit 1
  fi
}

_local_port() {
  local p
  if [[ -n "${OVPN_LOCAL_PORT:-}" ]]; then
    echo "${OVPN_LOCAL_PORT}"
    return
  fi
  if [[ -f "${LOCAL_PORT_FILE}" ]]; then
    p="$(tr -d '[:space:]' < "${LOCAL_PORT_FILE}" || true)"
    if [[ -n "${p}" ]]; then
      echo "${p}"
      return
    fi
  fi
  echo "11941"
}

_parse_remote() {
  # Sets REMOTE_HOST REMOTE_PORT from first "remote" line in OpenVPN config.
  local f="$1"
  local rest
  rest="$(grep -E '^[[:space:]]*remote[[:space:]]' "${f}" | head -1 | sed 's/^[[:space:]]*remote[[:space:]]\{1,\}//')" || true
  if [[ -z "${rest}" ]]; then
    echo "error: no 'remote' line in profile" >&2
    return 1
  fi
  # shellcheck disable=SC2086
  set -- ${rest}
  REMOTE_HOST="${1:-}"
  REMOTE_PORT="${2:-}"
  if [[ -z "${REMOTE_HOST}" || -z "${REMOTE_PORT}" ]]; then
    echo "error: could not parse remote host/port from: ${rest}" >&2
    return 1
  fi
}

_extract_ca_from_ovpn() {
  local src="$1" dst="$2"
  install -d -m 0755 "${STATE_DIR}"
  awk '
    /<ca>/ { p=1; next }
    p && /<\/ca>/ { exit }
    p { print }
  ' "${src}" > "${dst}.tmp"
  mv -f "${dst}.tmp" "${dst}"
  chmod 0644 "${dst}"
  if [[ ! -s "${dst}" ]]; then
    echo "error: empty or missing <ca> block" >&2
    return 1
  fi
}

_rewrite_ovpn_local_remote() {
  local src="$1" lp="$2" dst="$3"
  awk -v lp="${lp}" '
    /^[[:space:]]*remote[[:space:]]/ {
      if (!done) {
        sub(/^[[:space:]]*remote[[:space:]].*/, "remote 127.0.0.1 " lp)
        print
        done = 1
      }
      next
    }
    { print }
  ' "${src}" > "${dst}.tmp"
  if ! grep -qE '^[[:space:]]*remote[[:space:]]+127\.0\.0\.1[[:space:]]+'"${lp}"'([[:space:]]|$)' "${dst}.tmp"; then
    echo "error: failed to rewrite remote line for 127.0.0.1:${lp}" >&2
    rm -f "${dst}.tmp"
    return 1
  fi
  mv -f "${dst}.tmp" "${dst}"
  chmod 0644 "${dst}"
}

_ensure_unified_log() {
  install -d -m 0755 "$(dirname "${UNIFIED_LOG}")"
  : >> "${UNIFIED_LOG}"
  chmod 0644 "${UNIFIED_LOG}"
}

# Remove prior log-append lines, then add one right after the first "client" line.
_inject_ovpn_unified_log() {
  local conf="$1"
  local log="$2"
  grep -vE '^[[:space:]]*log-append[[:space:]]' "${conf}" > "${conf}.strip"
  mv -f "${conf}.strip" "${conf}"
  awk -v lf="${log}" '
    /^[[:space:]]*client[[:space:]]*$/ {
      print
      print "log-append " lf
      next
    }
    { print }
  ' "${conf}" > "${conf}.tmp"
  mv -f "${conf}.tmp" "${conf}"
  if ! grep -qF "log-append ${log}" "${conf}"; then
    echo "log-append ${log}" >> "${conf}"
  fi
  chmod 0644 "${conf}"
}

_write_stunnel_conf() {
  local connect_host="$1" connect_port="$2" lp="$3"
  install -d -m 0755 /etc/stunnel
  umask 022
  cat > "${STUNNEL_CONF}.tmp" <<EOF
; Managed by ovpn-panel-client — do not edit by hand unless you know the layout.
foreground = no
debug = notice
output = ${UNIFIED_LOG}

[openvpn]
client = yes
accept = 127.0.0.1:${lp}
connect = ${connect_host}:${connect_port}
verifyChain = yes
CAfile = ${CA_FILE}
EOF
  mv -f "${STUNNEL_CONF}.tmp" "${STUNNEL_CONF}"
  chmod 0644 "${STUNNEL_CONF}"
}

_write_ovpn_dropin() {
  install -d -m 0755 "${OVPN_DROPIN_DIR}"
  cat > "${OVPN_DROPIN}.tmp" <<EOF
# Managed by ovpn-panel-client
[Unit]
After=network-online.target ${STUNNEL_UNIT}
Requires=${STUNNEL_UNIT}
EOF
  mv -f "${OVPN_DROPIN}.tmp" "${OVPN_DROPIN}"
  chmod 0644 "${OVPN_DROPIN}"
}

_fetch_and_install() {
  local tmp lp
  tmp="$(mktemp)"
  if ! curl -fsSL --connect-timeout 15 --max-time 120 -H "Accept: text/plain" "$(cat "${URL_FILE}")" >"${tmp}"; then
    echo "error: failed to download subscription (check URL/network)" >&2
    rm -f "${tmp}"
    exit 1
  fi
  if ! grep -q '<ca>' "${tmp}"; then
    echo "error: response does not look like an inline OpenVPN profile" >&2
    rm -f "${tmp}"
    exit 1
  fi

  lp="$(_local_port)"
  printf '%s\n' "${lp}" > "${LOCAL_PORT_FILE}.tmp"
  mv -f "${LOCAL_PORT_FILE}.tmp" "${LOCAL_PORT_FILE}"
  chmod 0644 "${LOCAL_PORT_FILE}"

  REMOTE_HOST=""
  REMOTE_PORT=""
  _parse_remote "${tmp}"

  _ensure_unified_log
  _extract_ca_from_ovpn "${tmp}" "${CA_FILE}"
  _write_stunnel_conf "${REMOTE_HOST}" "${REMOTE_PORT}" "${lp}"

  install -d -m 0755 /etc/openvpn/client
  _rewrite_ovpn_local_remote "${tmp}" "${lp}" "${CLIENT_CONF}"
  _inject_ovpn_unified_log "${CLIENT_CONF}" "${UNIFIED_LOG}"
  rm -f "${tmp}"

  _write_ovpn_dropin
}

_need_url_file() {
  if [[ ! -f "${URL_FILE}" ]]; then
    echo "error: no saved URL. Run: ovpn-panel-client set-url <url>" >&2
    exit 1
  fi
}

cmd_set_url() {
  require_root
  local url="${1:-}"
  if [[ -z "${url}" ]]; then
    echo "error: missing URL" >&2
    exit 1
  fi
  install -d -m 0755 "${STATE_DIR}"
  umask 077
  printf '%s\n' "${url}" > "${URL_FILE}.tmp"
  mv -f "${URL_FILE}.tmp" "${URL_FILE}"
  chmod 600 "${URL_FILE}"

  _fetch_and_install

  systemctl daemon-reload
  systemctl enable "${STUNNEL_UNIT}"
  systemctl restart "${STUNNEL_UNIT}"
  systemctl enable "${OVPN_UNIT}"
  systemctl restart "${OVPN_UNIT}"
  echo "Stunnel: ${STUNNEL_CONF} -> ${STUNNEL_UNIT}"
  echo "OpenVPN: ${CLIENT_CONF} -> ${OVPN_UNIT} (remote 127.0.0.1:$(_local_port))"
  echo "Unified log: ${UNIFIED_LOG}  (ovpn-panel-client logs)"
}

cmd_refresh() {
  require_root
  _need_url_file
  _fetch_and_install
  systemctl daemon-reload
  systemctl restart "${STUNNEL_UNIT}"
  systemctl restart "${OVPN_UNIT}"
  echo "Refreshed configs and restarted ${STUNNEL_UNIT} and ${OVPN_UNIT}"
  echo "Unified log: ${UNIFIED_LOG}"
}

cmd_status() {
  echo "Local OpenVPN port: $(_local_port) (see ${LOCAL_PORT_FILE})"
  echo "Unified log: ${UNIFIED_LOG}"
  if [[ -f "${URL_FILE}" ]]; then
    echo "Subscription URL: ${URL_FILE} (mode $(stat -c '%a' "${URL_FILE}"))"
  else
    echo "Subscription URL: (not configured)"
  fi
  [[ -f "${STUNNEL_CONF}" ]] && echo "Stunnel: ${STUNNEL_CONF}" || echo "Stunnel: (no ${STUNNEL_CONF})"
  [[ -f "${CLIENT_CONF}" ]] && echo "OpenVPN: ${CLIENT_CONF}" || echo "OpenVPN: (missing profile)"
  echo "--- ${STUNNEL_UNIT} ---"
  systemctl status "${STUNNEL_UNIT}" --no-pager 2>/dev/null || true
  echo "--- ${OVPN_UNIT} ---"
  systemctl status "${OVPN_UNIT}" --no-pager 2>/dev/null || true
}

cmd_disable() {
  require_root
  systemctl disable --now "${OVPN_UNIT}" 2>/dev/null || true
  systemctl disable --now "${STUNNEL_UNIT}" 2>/dev/null || true
  echo "Stopped and disabled ${OVPN_UNIT} and ${STUNNEL_UNIT}"
}

cmd_logs() {
  if [[ ! -f "${UNIFIED_LOG}" ]]; then
    echo "error: no log file yet (${UNIFIED_LOG}). Run set-url first." >&2
    exit 1
  fi
  echo "Following ${UNIFIED_LOG} (Ctrl+C to stop)"
  tail -f "${UNIFIED_LOG}"
}

main() {
  local cmd="${1:-}"
  case "${cmd}" in
    set-url) shift; cmd_set_url "${1:-}" ;;
    refresh) cmd_refresh ;;
    status) cmd_status ;;
    logs) cmd_logs ;;
    disable) cmd_disable ;;
    -h|--help|help|'') usage; [[ -n "${cmd}" ]] || exit 0 ;;
    *) echo "error: unknown command: ${cmd}" >&2; usage >&2; exit 1 ;;
  esac
}

main "$@"
