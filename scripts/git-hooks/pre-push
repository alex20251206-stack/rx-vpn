#!/bin/bash
# Before push: align README example versions with the latest local vX.Y.Z tag.
# If README changes, creates a commit and aborts this push — run `git push` again.
# Skip: SKIP_README_SYNC=1 git push ...
set -euo pipefail

if [[ -n "${SKIP_README_SYNC:-}" ]]; then
  exit 0
fi

ROOT="$(git rev-parse --show-toplevel)"
SYNC="${ROOT}/scripts/sync-readme-version-from-latest-tag.sh"
if [[ ! -f "${SYNC}" ]]; then
  exit 0
fi

bash "${SYNC}"

if git -C "${ROOT}" diff --quiet README.md 2>/dev/null; then
  exit 0
fi

git -C "${ROOT}" add README.md
ver_line="$(git -C "${ROOT}" for-each-ref --sort=-version:refname --format '%(refname:short)' 'refs/tags/v*' 2>/dev/null | grep -E '^v[0-9]+\.[0-9]+\.[0-9]+$' | head -1 || true)"
git -C "${ROOT}" commit -m "docs: sync README to latest tag ${ver_line}" --no-verify
echo "pre-push: README.md updated to match latest tag (${ver_line}). Push again: git push" >&2
exit 1
