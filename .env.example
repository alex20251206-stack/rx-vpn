# Copy to .env and set at least OVPN_REMOTE_HOST.
# This host's public IPv4/IPv6 or DNS name (what clients use to reach stunnel :443).

OVPN_REMOTE_HOST=
OVPN_REMOTE_PORT=443
STUNNEL_ACCEPT=443

# Subscription links in the panel use OVPN_REMOTE_HOST with this scheme/port (optional).
# PANEL_PUBLIC_SCHEME=http
# PANEL_PUBLIC_PORT=8139
