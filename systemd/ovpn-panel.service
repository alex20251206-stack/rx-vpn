[Unit]
Description=OpenVPN admin panel (FastAPI)
After=network-online.target ovpn-data-init.service
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=-/etc/default/ovpn-panel
WorkingDirectory=/opt/panel
ExecStart=/usr/bin/python3 -m uvicorn app.main:app --host 0.0.0.0 --port 8139
StandardOutput=append:/logs/panel.log
StandardError=append:/logs/panel.log
Restart=always

[Install]
WantedBy=multi-user.target
